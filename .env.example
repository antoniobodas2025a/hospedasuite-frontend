# --------------------------------------------------------
# 1. CONEXIÓN A SUPABASE (Renombradas para Next.js)
# --------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# --------------------------------------------------------
# 2. INTELIGENCIA ARTIFICIAL (REQUERIDO PARA OCR)
# --------------------------------------------------------
GEMINI_API_KEY=tu_gemini_api_key

# --------------------------------------------------------
# 3. SEGURIDAD (SOLO SERVIDOR - MODO DIOS)
# --------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --------------------------------------------------------
# 4. WOMPI - PASARELA DE PAGOS
# --------------------------------------------------------
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_EVENTS_SECRET=test_events_...
HQ_WOMPI_INTEGRITY_SECRET=test_integrity_...

# Wompi Platform Keys (para facturación de suscripciones de HospedaSuite)
WOMPI_PLATFORM_PUBLIC_KEY=pub_test_...
WOMPI_PLATFORM_INTEGRITY_SECRET=test_integrity_...

# --------------------------------------------------------
# 5. EMAIL (RESEND)
# --------------------------------------------------------
RESEND_API_KEY=re_...
NEXT_PUBLIC_APP_URL=https://www.hospedasuite.com
EMAIL_FROM="HospedaSuite <reservas@hospedasuite.com>"

# --------------------------------------------------------
# 6. QSTASH (Cron jobs / Webhooks)
# --------------------------------------------------------
QSTASH_URL="https://qstash-us-east-1.upstash.io"
QSTASH_TOKEN=ey...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# --------------------------------------------------------
# 7. SECRETO CRON
# --------------------------------------------------------
CRON_SECRET="tu_secreto_cron"

# --------------------------------------------------------
# 8. ANALYTICS (POSTHOG)
# --------------------------------------------------------
# Crear cuenta gratuita en https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --------------------------------------------------------
# 9. IMÁGENES — Cloudflare R2
# --------------------------------------------------------
# Fuentes soportadas: 'supabase' | 'r2' | 'local' | 'external'
NEXT_PUBLIC_IMAGE_SOURCE=r2
NEXT_PUBLIC_IMAGE_BASE_URL=https://pub-xxxxx.r2.dev
NEXT_PUBLIC_IMAGE_FALLBACK_URL=

# R2 Server-side credentials (para presigned URLs)
# Obtener desde Cloudflare Dashboard > R2 > Manage R2 API Tokens
# Access Key ID: 32 chars hex (sin prefijo cfat_)
# Secret Access Key: 64 chars hex
R2_ACCESS_KEY_ID=<32-char-hex>
R2_SECRET_ACCESS_KEY=<64-char-hex>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=hospedasuite-media
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# --------------------------------------------------------
# 10. EVENT-DRIVEN MODE
# --------------------------------------------------------
# Set to 'true' to enable emitEvent() in development.
# In production, events are always sent to QStash regardless of this flag.
EVENT_DRIVEN_MODE=false

# --------------------------------------------------------
# 11. FEATURES
# --------------------------------------------------------
NEXT_PUBLIC_SMART_SEARCH=true

# --------------------------------------------------------
# 12. GOOGLE MAPS (Static API — optional)
# --------------------------------------------------------
# Used for static map images in hotel detail pages.
# If not configured, a textual location card is shown instead.
# Get your API key: https://console.cloud.google.com/google/maps-apis
# Free tier: $200/month credit (approx 28,000 static map requests)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
