{
  "scenario": "totiao_instagram_dm_automation",
  "trigger": {
    "platform": "instagram",
    "event": "new_comment",
    "keyword": "ANTOJO",
    "post_type": "reel"
  },
  "nodes": [
    {
      "id": "1",
      "type": "webhook",
      "name": "Interceptar Comentario",
      "config": {
        "method": "POST",
        "path": "/webhooks/instagram/comment",
        "payload_mapping": {
          "user_id": "{{body.from.id}}",
          "username": "{{body.from.username}}",
          "comment_text": "{{body.text}}",
          "media_id": "{{body.media.id}}"
        }
      }
    },
    {
      "id": "2",
      "type": "filter",
      "name": "Validar Keyword",
      "config": {
        "condition": "{{body.text}} contains 'ANTOJO'",
        "true_path": "3",
        "false_path": "end"
      }
    },
    {
      "id": "3",
      "type": "http_request",
      "name": "Obtener Perfil Usuario",
      "config": {
        "method": "GET",
        "url": "https://graph.instagram.com/{{body.from.id}}",
        "headers": {
          "Authorization": "Bearer {{instagram_access_token}}"
        }
      }
    },
    {
      "id": "4",
      "type": "action",
      "name": "Enviar DM Automático",
      "config": {
        "method": "POST",
        "url": "https://graph.instagram.com/me/messages",
        "body": {
          "recipient": {
            "id": "{{body.from.id}}"
          },
          "message": {
            "text": "¡El CRUNCH no miente! 🥩🔥 Aquí tienes tu acceso directo a la lista VIP de Totiao para que sepas el día exacto de apertura: https://hospedasuite.com/totiao_vip"
          }
        }
      }
    }
  ],
  "copy_rules": {
    "forbidden_words": ["Próximamente", "En construcción", "Disculpa", "Aún no abrimos"],
    "mandatory_phrase": "¡El CRUNCH no miente! 🔥"
  }
}
