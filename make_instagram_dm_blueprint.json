{
  "name": "Totiao VIP Funnel Automation",
  "version": "1.0",
  "description": "Automated Instagram DM funnel triggered by keyword comment",
  "trigger": {
    "platform": "instagram",
    "event": "new_comment",
    "keyword_filter": "ANTOJO",
    "webhook_config": {
      "method": "POST",
      "path": "/webhooks/instagram/comment",
      "headers": {
        "Content-Type": "application/json"
      }
    }
  },
  "workflow": [
    {
      "step": 1,
      "action": "validate_comment",
      "description": "Check if comment contains keyword 'ANTOJO'",
      "logic": "if (comment.text.includes('ANTOJO')) proceed else end"
    },
    {
      "step": 2,
      "action": "get_user_profile",
      "description": "Retrieve user ID and username from comment payload",
      "api_call": {
        "method": "GET",
        "url": "https://graph.instagram.com/{{comment.from.id}}",
        "auth": "Bearer {{instagram_access_token}}"
      }
    },
    {
      "step": 3,
      "action": "send_direct_message",
      "description": "Send automated DM with VIP access link",
      "api_call": {
        "method": "POST",
        "url": "https://graph.instagram.com/me/messages",
        "body": {
          "recipient": {
            "id": "{{user.id}}"
          },
          "message": {
            "text": "¡El CRUNCH no miente! 🥩🔥 Aquí tienes tu acceso directo a la lista VIP de Totiao para que sepas el día exacto de apertura: https://hospedasuite.com/totiao_vip"
          }
        }
      }
    }
  ],
  "copy_rules": {
    "mandatory_phrase": "¡El CRUNCH no miente! 🔥",
    "forbidden_words": ["Próximamente", "En construcción", "Disculpa", "Aún no abrimos"],
    "link_target": "https://hospedasuite.com/totiao_vip"
  }
}
